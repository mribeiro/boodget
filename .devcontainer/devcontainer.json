{
  "name": "Capital Tracker Dev",
  "dockerComposeFile": ["../docker-compose.yml", "../docker-compose.devcontainer.yml"],
  "service": "capital-tracker",
  "workspaceFolder": "/workspaces/money_manager",
  "overrideCommand": true,
  "forwardPorts": [3000, 5173],
  "postCreateCommand": "cd backend && npm install && cd ../frontend && npm install",
  "postStartCommand": "cd backend && npm run dev &  cd frontend && npm run dev &",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },
  "remoteEnv": {
    "SESSION_SECRET": "dev-only-secret-change-in-production",
    "DB_PATH": "/workspaces/money_manager/data/capital-tracker.db"
  }
}
